{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "clanker-captcha",
  "main": "src/worker.js",
  "compatibility_date": "2026-05-31",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
